{
  "manifest_version": 3,
  "name": "WordWise",
  "version": "1.3.0",
  "description": "阅读即学词 — 智能标注生词、AI 文章摘要、PDF 阅读，纯前端零后端",
  "permissions": ["storage", "activeTab", "tabs", "offscreen", "unlimitedStorage"],
  "host_permissions": [],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["lib/katex/katex.min.js", "content.js"],
      "css": ["lib/katex/katex.min.css", "content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "lib/pdfjs/*",
        "lib/katex/*",
        "lib/katex/fonts/*",
        "lib/data/*",
        "offscreen.html"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}