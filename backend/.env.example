WORDWISE_DATABASE_URL=sqlite+aiosqlite:///./wordwise.db
WORDWISE_JWT_SECRET_KEY=replace-with-a-long-random-secret
WORDWISE_ACCESS_TOKEN_EXPIRE_DAYS=30
WORDWISE_TEST_SESSION_EXPIRE_MINUTES=30
WORDWISE_TRANSLATOR_API_KEY=
WORDWISE_TRANSLATOR_API_URL=
WORDWISE_TRANSLATOR_MODEL=
# hybrid = 本地词典优先 + LLM 兜底 | local_wordbook = 纯本地 | remote = 纯 LLM
WORDWISE_TRANSLATOR_MODE=hybrid
WORDWISE_LOCAL_WORDBOOK_PATH=./data/ielts_wordbook.json
WORDWISE_LOCAL_DICTIONARY_DB_PATH=./data/ecdict.db
WORDWISE_LOCAL_DICTIONARY_CSV_PATH=./data/ecdict.csv
